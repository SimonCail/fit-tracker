{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.1.10",
      "memory": 512,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/__/auth/:path*", "destination": "https://fit-tracker-f28ce.firebaseapp.com/__/auth/:path*" },
    { "source": "/__/firebase/:path*", "destination": "https://fit-tracker-f28ce.firebaseapp.com/__/firebase/:path*" },
    { "source": "/((?!api/|__/).*)", "destination": "/index.html" }
  ]
}
